# ----------------------------------------------------------------------------
# Anamnèse — variables d'environnement
# Copie ce fichier en .env.local puis remplis les valeurs (cf. SETUP.md).
# .env.local est ignoré par git. Ne jamais commiter de vraie clé.
# ----------------------------------------------------------------------------

# Supabase — Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# ⚠️ bypasse RLS — SERVEUR UNIQUEMENT, jamais exposé au client
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Unsplash — https://unsplash.com/developers → application Access Key
UNSPLASH_ACCESS_KEY=

# Google Custom Search (optionnel, fallback de dernier recours)
# https://programmablesearchengine.google.com/ + https://console.cloud.google.com/apis/credentials
# Laisse vide pour désactiver : le pipeline utilisera juste Wikimedia + Unsplash.
GOOGLE_CSE_ID=
GOOGLE_CSE_KEY=
